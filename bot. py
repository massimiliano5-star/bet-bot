CHAT_ID = "545852688"

def send_telegram(msg):
    url = f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage"
    try:
        response = requests.post(url, data={
            "chat_id": CHAT_ID,
            "text": msg
        })
        if response.status_code != 200:
            print("Errore invio:", response.text)
    except Exception as e:
        print("Errore:", e)

